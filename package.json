{
  "name": "@ylmz/performance-analyzer-mcp",
  "version": "1.0.0",
  "description": "网页性能分析MCP服务",
  "main": "build/index.js",
  "bin": {
    "performance-mcp": "build/index.js"
  },
  "type": "module",
  "files": [
    "build/**/*",
    "scripts/**/*",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsc",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "npm run build",
    "postinstall": "playwright-core install chromium",
    "start": "node build/index.js",
    "start:sse": "node build/index.js --transport=sse",
    "dev": "ts-node-esm src/index.ts",
    "dev:sse": "ts-node-esm src/index.ts --transport=sse",
    "client:sse": "node scripts/sse-client.js"
  },
  "keywords": [
    "mcp",
    "performance",
    "web",
    "analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.1.0",
    "@types/body-parser": "^1.19.5",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "eventsource": "^2.0.2",
    "express": "^4.18.2",
    "install": "^0.13.0",
    "nanoid": "^4.0.2",
    "node-fetch": "^3.3.1",
    "playwright-core": "^1.38.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.17",
    "@types/node": "^20.6.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}